# BABEL — environment variables template
# Copy to .env and fill in your keys. Never commit the real .env.
# Everything runs on NVIDIA NIM (free, OpenAI-compatible) at build.nvidia.com.

# ── TEXT: NVIDIA NIM (chapter transform + glossary extraction) ──────────
# Sign up at https://build.nvidia.com, generate API key(s) (start "nvapi-").
# Provide MULTIPLE comma-separated keys for automatic rotation — this is the
# main way to avoid the 40 RPM free-tier limit at scale.
# Primary model: qwen/qwen3-235b-a22b, fallback: deepseek-ai/deepseek-v3.1.
# Aliases for --model: qwen | deepseek | llama | mistral-nemotron | nemotron
NVIDIA_API_KEYS=nvapi-text-key-1,nvapi-text-key-2

# ── VISUAL: NVIDIA NIM image models (character renders / VN sprites) ─────
# Separate key pool so image generation never competes with text for rate
# limit. Falls back to NVIDIA_API_KEYS if unset.
NVIDIA_VISION_API_KEYS=nvapi-vision-key-1,nvapi-vision-key-2

# ── Optional: Google Gemini (not in the default path) ──────────────────
# GEMINI_API_KEY=your-gemini-key-here

# ── Optional: local Ollama (fully offline) ─────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
