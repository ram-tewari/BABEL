{
  "blocks": [
    {
      "type": "action",
      "speaker": null,
      "content": "Arkane knew someone had invaded his dungeon last night.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "But he didn't care.",
      "tone": null
    },
    {
      "type": "narrator",
      "speaker": null,
      "content": "Countless thieves targeted a Grand Mage's dungeon.",
      "tone": null
    },
    {
      "type": "narrator",
      "speaker": null,
      "content": "By now, they'd likely been killed by monsters or traps.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "Dismissing the thought, Arkane focused on his research.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "His recent interest was dark magic's effect on memory.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "As he scribbled notes, his hand suddenly stopped.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "He removed his glasses and looked toward the door.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "Mechanisms were being disarmed at an alarming speed.",
      "tone": null
    },
    {
      "type": "narrator",
      "speaker": null,
      "content": "This was no ordinary intruder.",
      "tone": null
    },
    {
      "type": "dialogue",
      "speaker": "Arkane",
      "content": "Did I catch a big one today?",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "For Arkane, who could hole up for years, dungeon intruders were entertainment.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "Today's catch seemed particularly interesting.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "With a thud, the iron door opened.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "Arkane checked his watch.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "Exactly 32 hours, 28 minutes, and 5 seconds since entry.",
      "tone": null
    },
    {
      "type": "action",
      "speaker": null,
      "content": "The time taken to disarm every trap and reach this point.",
      "tone": null
    }
  ],
